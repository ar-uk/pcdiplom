<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.Androidapp" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary_container</item>
        <item name="colorOnPrimary">@color/on_primary_container</item>
        <item name="colorPrimaryContainer">@color/primary_fixed_dim</item>
        <item name="colorOnPrimaryContainer">@color/on_primary_fixed</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        <item name="colorSecondaryContainer">@color/secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/on_secondary_container</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorOnBackground">@color/on_background</item>
        <item name="colorSurface">@color/surface_container</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant</item>
        <item name="colorOutline">@color/outline</item>
        <item name="colorOutlineVariant">@color/outline_variant</item>
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/on_error</item>
        <item name="android:statusBarColor">@color/surface_container_lowest</item>
        <item name="android:navigationBarColor">@color/surface_container_lowest</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:windowBackground">@drawable/bg_screen_gradient</item>
        <item name="materialButtonStyle">@style/Widget.Rig.Button.Primary</item>
        <item name="materialCardViewStyle">@style/Widget.Rig.Card.Glass</item>
        <item name="textInputStyle">@style/Widget.Rig.TextInput</item>
        <item name="toolbarStyle">@style/Widget.Rig.Toolbar</item>
    </style>

    <style name="Theme.Androidapp" parent="Base.Theme.Androidapp" />

    <style name="Widget.Rig.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@drawable/toolbar_scrim</item>
    </style>

    <style name="TextAppearance.Rig.ToolbarTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">20sp</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.Rig.Display" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/on_background</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.Rig.Headline" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.Rig.SectionLabel" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textColor">@color/primary_fixed_dim</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:fontFamily">monospace</item>
    </style>

    <style name="TextAppearance.Rig.Body" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/on_surface_variant</item>
    </style>

    <style name="TextAppearance.Rig.LabelSmall" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textColor">@color/on_surface_variant</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <style name="Widget.Rig.Button.Primary" parent="Widget.Material3.Button">
        <item name="cornerRadius">@dimen/radius_lg</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="backgroundTint">@color/primary_container</item>
        <item name="android:textColor">@color/on_primary_container</item>
    </style>

    <style name="Widget.Rig.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">@dimen/radius_sm</item>
        <item name="android:textAllCaps">false</item>
        <item name="strokeColor">@color/outline_variant</item>
        <item name="android:textColor">@color/on_surface_variant</item>
    </style>

    <style name="Widget.Rig.Card.Glass" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/glass_fill</item>
        <item name="cardCornerRadius">@dimen/radius_lg</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/glass_stroke</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.Rig.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">@dimen/radius_sm</item>
        <item name="boxCornerRadiusTopEnd">@dimen/radius_sm</item>
        <item name="boxCornerRadiusBottomStart">@dimen/radius_sm</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/radius_sm</item>
        <item name="boxStrokeColor">@color/outline_variant</item>
        <item name="hintTextColor">@color/on_surface_variant</item>
        <item name="android:textColorHint">@color/on_surface_variant</item>
    </style>

    <style name="AppTheme" parent="Theme.Androidapp" />

    <style name="Widget.AppButton" parent="Widget.Rig.Button.Primary" />

    <style name="Card.Elevated" parent="Widget.Rig.Card.Glass" />

    <style name="TitleText" parent="TextAppearance.Rig.Headline" />

    <style name="BodyText" parent="TextAppearance.Rig.Body" />
</resources>
