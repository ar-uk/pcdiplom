<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".ProfileSettingsActivity">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:padding="@dimen/container_padding"
        android:paddingBottom="@dimen/padding_bottom_chrome_nav">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/stack_lg">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/stack_sm"
                android:text="@string/settings_title"
                android:textColor="@color/on_surface"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/settings_subtitle"
                android:textAppearance="@style/TextAppearance.Rig.Body" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Rig.Card.Glass"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/stack_md"
                app:strokeColor="@color/outline_variant"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/gutter">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_section_account"
                        android:textAppearance="@style/TextAppearance.Rig.SectionLabel" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/stack_sm"
                        android:text="@string/settings_label_username"
                        android:textAppearance="@style/TextAppearance.Rig.LabelSmall"
                        android:textColor="@color/on_surface_variant" />

                    <TextView
                        android:id="@+id/settings_account_username"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textAppearance="@style/TextAppearance.Rig.Body"
                        tools:text="johndoe" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/stack_sm"
                        android:text="@string/settings_label_email"
                        android:textAppearance="@style/TextAppearance.Rig.LabelSmall"
                        android:textColor="@color/on_surface_variant" />

                    <TextView
                        android:id="@+id/settings_account_email"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textAppearance="@style/TextAppearance.Rig.Body"
                        tools:text="user@mail" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/stack_md"
                        android:text="@string/settings_section_appearance"
                        android:textAppearance="@style/TextAppearance.Rig.SectionLabel" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/settings_theme_light"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/stack_sm"
                        android:text="@string/settings_light_theme"
                        app:useMaterialThemeColors="true" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Rig.Card.Glass"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gutter"
                app:strokeColor="@color/outline_variant"
                app:strokeWidth="1dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/gutter"
                    android:text="@string/settings_about_body"
                    android:textAppearance="@style/TextAppearance.Rig.Body" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/settings_sign_out"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/stack_md"
                android:text="@string/settings_sign_out"
                android:textColor="@color/error"
                app:strokeColor="@color/error" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <include
        layout="@layout/include_shell_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
