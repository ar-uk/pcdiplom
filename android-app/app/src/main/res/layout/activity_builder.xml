<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".BuilderActivity">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingStart="@dimen/container_padding"
        android:paddingEnd="@dimen/container_padding"
        android:paddingBottom="@dimen/padding_bottom_chrome_nav">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/stack_lg">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/builder_title"
                android:textColor="@color/primary_fixed"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/builder_subtitle"
                android:textAppearance="@style/TextAppearance.Rig.Body" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Rig.Card.Glass"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/stack_md"
                app:strokeColor="@color/outline_variant"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingVertical="12dp"
                    android:paddingStart="@dimen/gutter"
                    android:paddingEnd="@dimen/gutter">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/builder_total_estimate"
                            android:textAppearance="@style/TextAppearance.Rig.LabelSmall" />

                        <TextView
                            android:id="@+id/total_estimate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="@color/primary_container"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="36dp"
                        android:background="@color/outline_variant" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/gutter"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/builder_power_hint"
                            android:textAppearance="@style/TextAppearance.Rig.LabelSmall"
                            android:textColor="@color/primary_fixed" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <ProgressBar
                android:id="@+id/selection_progress_bar"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginTop="@dimen/stack_md"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/progress_horizontal_rig" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/selection_progress_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/builder_progress_start"
                    android:textAppearance="@style/TextAppearance.Rig.LabelSmall"
                    android:textColor="@color/primary_fixed" />

                <TextView
                    android:id="@+id/selection_percent_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textAppearance="@style/TextAppearance.Rig.LabelSmall"
                    android:textColor="@color/on_surface_variant" />
            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/stack_md"
                android:clipToPadding="false"
                android:fillViewport="true"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/category_buttons"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingEnd="4dp" />
            </HorizontalScrollView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gutter"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Rig.TextInput"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="@string/builder_search_hint">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/search_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:textColor="@color/on_surface" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/toggle_order"
                    style="@style/Widget.Rig.Button.Outlined"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/builder_sort_price" />
            </LinearLayout>

            <TextView
                android:id="@+id/parts_compat_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/stack_sm"
                android:paddingVertical="8dp"
                android:paddingHorizontal="@dimen/gutter"
                android:textAppearance="@style/TextAppearance.Rig.LabelSmall"
                android:textColor="@color/primary_fixed"
                android:visibility="gone" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/stack_md"
                android:text="@string/builder_catalog"
                android:textAppearance="@style/TextAppearance.Rig.SectionLabel" />

            <LinearLayout
                android:id="@+id/parts_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/stack_sm"
                android:orientation="vertical" />

            <LinearLayout
                android:id="@+id/parts_pagination"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/stack_sm"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone"
                tools:visibility="visible">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/parts_page_prev"
                    style="@style/Widget.Rig.Button.Outlined"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/builder_page_prev" />

                <TextView
                    android:id="@+id/parts_page_meta"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="8dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:textAppearance="@style/TextAppearance.Rig.LabelSmall"
                    android:textColor="@color/on_surface_variant"
                    tools:text="Page 1 of 3 · 1–24 of 60" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/parts_page_next"
                    style="@style/Widget.Rig.Button.Outlined"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/builder_page_next" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Rig.Card.Glass"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/stack_md"
                app:strokeColor="@color/primary_fixed_dim"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/gutter">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/builder_selected_slot"
                        android:textAppearance="@style/TextAppearance.Rig.SectionLabel" />

                    <LinearLayout
                        android:id="@+id/selected_list"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/stack_sm"
                        android:orientation="vertical" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gutter"
                android:text="@string/builder_build_name"
                android:textAppearance="@style/TextAppearance.Rig.LabelSmall"
                android:textColor="@color/on_surface_variant" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Rig.TextInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:hint="@string/builder_build_name_hint">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/build_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapWords"
                    android:textColor="@color/on_surface" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/save_build"
                style="@style/Widget.Rig.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gutter"
                android:text="@string/builder_finalize" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/stack_sm"
                android:gravity="center"
                android:paddingHorizontal="@dimen/gutter"
                android:text="@string/builder_finalize_disclaimer"
                android:textAppearance="@style/TextAppearance.Rig.LabelSmall"
                android:textColor="@color/on_surface_variant" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <include
        layout="@layout/include_shell_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
